# Supabase Database Connection URL
DATABASE_URL=your-secret-key-here

# Supabase Public API Keys
NEXT_PUBLIC_SUPABASE_URL=your-secret-key-here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-secret-key-here

# Site URL (used for SEO metadata, defaults to http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend API Key
RESEND_API_KEY=your-secret-key-here
RESEND_EMAIL_FROM=your-email@example.com
